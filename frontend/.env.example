# Backend server URL (used in production/remote dev mode)
VITE_BACKEND_SERVER=https://dattvayaan.live/

# Website URL (used for links in emails and redirects)
VITE_WEBSITE_URL=https://dattvayaan.live/

# Optional: Base URL for file downloads (e.g. S3 or DO Spaces CDN URL)
# VITE_FILE_BASE_URL=https://your-cdn.example.com/

# Set to "remote" to proxy API calls to VITE_BACKEND_SERVER during local dev
# VITE_DEV_REMOTE=remote
