# MongoDB connection URI
DATABASE=mongodb+srv://<username>:<password>@cluster.mongodb.net/dattva-yaan?retryWrites=true&w=majority

# JWT secret for signing authentication tokens (use a long random string)
JWT_SECRET=your_jwt_secret_here

# Port the backend server listens on (defaults to 8888)
PORT=8888

# Production domain base URL (used in email links)
APP_BASE_URL=https://dattvayaan.live/

# Contact / notification email address
APP_EMAIL=your@email.com

# Resend API key for transactional email delivery
# RESEND_API=re_xxxxxxxxxxxxxxxxxxxx

# OpenAI API key (optional, for AI features)
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# DigitalOcean Spaces / S3-compatible object storage (optional)
# DO_SPACES_KEY=your_spaces_key
# DO_SPACES_SECRET=your_spaces_secret
# DO_SPACES_NAME=your_bucket_name
# DO_SPACES_URL=https://your_bucket.region.digitaloceanspaces.com
# REGION=nyc3

# Public server file path (optional)
# PUBLIC_SERVER_FILE=https://dattvayaan.live/public/
